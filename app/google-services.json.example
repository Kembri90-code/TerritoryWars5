# Этот файл - stub для разработки
# Замените на реальный google-services.json из Firebase Console:
#
# 1. Перейдите на https://console.firebase.google.com/
# 2. Создайте новый проект (или используйте существующий)
# 3. Добавьте Android приложение:
#    - Package name: com.territorywars
#    - SHA-1: (получите из Android Studio)
# 4. Скачайте google-services.json
# 5. Поместите этот файл вместо текущего в app/google-services.json
#
# ДО КОММИТА В GIT: убедитесь что google-services.json в .gitignore!

{
  "type": "service_account",
  "project_id": "territory-wars-dev",
  "private_key_id": "REPLACE_WITH_REAL_KEY",
  "private_key": "REPLACE_WITH_REAL_PRIVATE_KEY",
  "client_email": "REPLACE_WITH_REAL_EMAIL",
  "client_id": "REPLACE_WITH_REAL_CLIENT_ID",
  "auth_uri": "https://accounts.google.com/o/oauth2/auth",
  "token_uri": "https://oauth2.googleapis.com/token"
}
